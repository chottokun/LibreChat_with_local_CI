# =============================================================================
# LibreChat & Code Interpreter API 環境変数設定テンプレート
# =============================================================================
# このファイルは、LibreChat本体と Code Interpreter API (RCE) の両方の設定を網羅しています。
# 「cp .env.librechat .env」としてコピーするだけで、最低限のテスト動作が可能です。
#
# 【重要】セキュリティのため、運用環境では必ず以下の「変更必須項目」を更新してください。
# =============================================================================

# -----------------------------------------------------------------------------
# ■ 変更必須項目 (セキュリティ・認証設定)
# -----------------------------------------------------------------------------

# [REQUIRED] JWT 認証用のシークレットキー。
# 運用環境では必ず推測困難な32文字以上のランダムな文字列に変更してください。
JWT_SECRET=32_char_secret_key_used_for_testing_123
JWT_REFRESH_SECRET=32_char_refresh_key_used_for_testing_456

# [REQUIRED] 認証情報の暗号化キーとIV。
# 運用環境では必ず変更してください。
CREDS_KEY=f34be427ebaeded2940f7d30100edb51
CREDS_IV=12345678901234567890123456789012

# [REQUIRED] APIアクセスのための共有キー。
# API サーバーと LibreChat の間で一致させる必要があります。
LIBRECHAT_CODE_API_KEY=your_secret_key

# -----------------------------------------------------------------------------
# ■ デフォルトで動作可能な設定項目
# -----------------------------------------------------------------------------

# 1. API サーバー (FastAPI) & Docker Socket Proxy
# -----------------------------------------------------------------------------

# Docker APIへの接続URL。通常は変更不要です。
DOCKER_HOST=tcp://docker-proxy:2375

# 2. Code Interpreter サンドボックス (RCE) 設定
# -----------------------------------------------------------------------------

# 実行環境として使用する Docker イメージ。
RCE_IMAGE_NAME=custom-rce-kernel:latest

# 各コンテナのメモリ制限。
RCE_MEM_LIMIT=512m

# 各コンテナのCPU制限（ナノ秒）。500000000 = 0.5 CPU。
RCE_CPU_LIMIT=500000000

# 最大同時セッション数。
RCE_MAX_SESSIONS=100

# アイドルコンテナの有効期限（秒）。
RCE_SESSION_TTL=3600

# 外部ネットワークアクセスの許可 (true/false)。
RCE_NETWORK_ENABLED=false

# GPU の有効化 (true/false)。
RCE_GPU_ENABLED=false

# 3. ファイルストレージ & 永続化
# -----------------------------------------------------------------------------

# [OPTIONAL] ホスト側のデータ保存用ディレクトリ。
# 設定すると永続化と高速なファイルアクセスが有効になります。
# RCE_DATA_DIR=/app/shared_volumes/sessions

# APIコンテナ内部でのセッションデータ保存パス。
RCE_DATA_DIR_INTERNAL=/app/shared_volumes/sessions

# LibreChatのファイル保存形式。
STORAGE_TYPE=local

# 4. LibreChat 基本インフラ (DB, 検索)
# -----------------------------------------------------------------------------

# MongoDB 接続 URL。
MONGO_URI=mongodb://mongodb:27017/LibreChat

# Meilisearch 設定。
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=your_master_key
MEILI_NO_ANALYTICS=true

# LibreChat 設定ファイルのパス。
CONFIG_PATH=/app/librechat.yaml
CONFIG_BYPASS_VALIDATION=true
ALLOW_REGISTRATION=true

# 5. 連携設定
# -----------------------------------------------------------------------------

# LibreChatからAPIへの接続パス。
LIBRECHAT_CODE_BASEURL=http://librechat_code_interpreter_api:8000

# 6. AI モデル設定
# -----------------------------------------------------------------------------

# OpenAI API (テスト用にダミーキーを設定済み)
OPENAI_API_KEY=sk-dummy-key-for-ui-testing

# Google Gemini 設定
GEMINI_API_KEY=your-gemini-api-key-here

# Ollama 設定
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODELS=qwen2.5-coder:3b

# 外部互換 API
EXTERNAL_API_URL=https://api.example.com/v1/
EXTERNAL_API_KEY=your_external_api_key_here
EXTERNAL_LLM_MODEL=gpt-4o

# 7. サーバー起動設定
# -----------------------------------------------------------------------------

HOST=0.0.0.0
PORT=3080
